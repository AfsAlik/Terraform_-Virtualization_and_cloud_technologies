resource "proxmox_vm_qemu" "gitlab" {
# Уникальный идентификатор виртуальной машины в Proxmox
 vmid             = 180
# Имя виртуальной машины, которое будет отображаться в интерфейсе Proxmox
 name             = "gitlab"
# Имя узла Proxmox (ноды), на котором будет создана ВМ
 target_node      = var.target_node    
# Включение QEMU Guest Agent (1 = включен)
# Позволяет хосту получать информацию о ВМ и выполнять команды внутри нее   
 agent            = 1
# Отключение аппаратной виртуализации KVM
# false = использовать эмуляцию (может быть нужно для некоторых типов гостевых ОС)
 kvm              = false
# Блок конфигурации процессора
 cpu {
# Количество ядер процессора, выделяемых ВМ
    cores   = 1
# Количество сокетов (физических процессоров)
    sockets = 1
# Тип эмулируемого процессора (kvm64 - совместимый тип для большинства ОС)
    type    = "kvm64"
  }
# Объем оперативной памяти в мегабайтах (2 ГБ)
 memory           = 2048
# Порядок загрузки: первым устройством загрузки будет SCSI диск
 boot             = "order=scsi0"
 # Имя шаблона, с которого будет клонирована ВМ
 clone            = "web-server-01"
# Полное клонирование (true = создается независимая копия всех дисков)    
 full_clone       = true
# Тип SCSI контроллера (virtio-scsi-single дает лучшую производительность)
 scsihw           = "virtio-scsi-single"
# Желаемое состояние ВМ после создания (running = запущена)
 vm_state         = "running"
# Автоматически перезагружать ВМ при необходимости
 automatic_reboot = true
# Настройка cloud-init: путь к файлу с пользовательскими скриптами
#этот момент описан по ссылке выше, если вкратце - мы передаём команды, 
#которые будут введены после старта склонированной ВМ
 cicustom   = "vendor=local:snippets/qemu-guest-agent.yml" 
# Обновлять пакеты при использовании cloud-init (true = выполнить apt update/upgrade)
 ciupgrade  = true
# DNS-сервер для ВМ (пустая строка = использовать настройки по умолчанию)
 nameserver = ""
# Настройка сети: IP-адрес и шлюз для первого интерфейса (eth0)
 ipconfig0  = "ip=${var.vm_ip},gw=${var.vm_gateway}"      
# Отключение IPv6 (true = не настраивать IPv6)
skip_ipv6  = true
#Имя пользователя, который будет создан в ВМ
 ciuser     = "nikita"
# Пароль пользователя 
 cipassword = var.vm_password        
# SSH-ключи для доступа к ВМ
 sshkeys    = var.ssh_public_key != "" ? var.ssh_public_key : null
 
#эта секция не используется, нужна для защиты ВМ от случайного удаления при использовании командной строки terraform
# lifecycle {
#   prevent_destroy = true
# }
# Настройка последовательного порта
 serial {
   id = 0
 }
# Блок конфигурации дисков
 disks {
# Конфигурация SCSI дисков (основные диски ВМ)
   scsi {
     scsi0 {
       disk {
# Хранилище, где будет размещен диск (local-lvm - стандартное LVM хранилище Proxmox)
         storage = "local-lvm"
# Размер диска
         size    = "20G"
       }
     }
   }
# Конфигурация IDE дисков (обычно используется для cloud-init)
   ide {
     ide2 {
# Cloud-init диск для автоматической настройки ВМ при первом запуске
       cloudinit {
# Хранилище для cloud-init образа
         storage = "local-lvm"
       }
     }
   }
 }
# Конфигурация сетевого интерфейса
 network {
# Номер сетевого интерфейса (0 = первый)
   id     = 0
# Мост, к которому подключается ВМ
   bridge = "vmbr0"
# Тип сетевого адаптера
   model  = "virtio"
 }
}
